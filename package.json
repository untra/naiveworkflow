{
  "name": "naiveworkflow-monorepo",
  "version": "0.0.2",
  "private": true,
  "description": "Visualize Claude workflow scripts as diagramed directed graphs.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "dev": "pnpm --filter playground dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "ci": "biome ci . && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
