{
  "name": "@untra/naiveworkflow-react",
  "version": "0.0.0",
  "description": "React renderer: flattens naiveworkflow IR, lays it out with dagre, and draws a dependency graph with React Flow.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@untra/naiveworkflow-compiler": "workspace:*",
    "dagre": "^0.8.5"
  },
  "peerDependencies": {
    "@xyflow/react": "^12.0.0",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.1.0",
    "@types/dagre": "^0.7.52",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@xyflow/react": "^12.3.6",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}
