{
  "name": "@untra/naiveworkflow-compiler",
  "version": "0.0.3",
  "description": "Static compiler: Claude workflow JS → coordinate-free IR JSON. Never executes the source.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./ir": {
      "types": "./dist/ir.d.ts",
      "import": "./dist/ir.js",
      "require": "./dist/ir.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "acorn": "^8.14.0",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.24.1"
  },
  "devDependencies": {
    "@types/estree": "^1.0.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.7"
  }
}
